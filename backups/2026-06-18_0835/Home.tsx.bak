function useTypewriter(words: string[], typingSpeed = 60, pause = 1400) {
  const [text, setText] = useState('')
  const [idx, setIdx] = useState(0)
  const [isDeleting, setIsDeleting] = useState(false)

  useEffect(() => {
    const current = words[idx % words.length]
    let timeout: number

    if (!isDeleting) {
      timeout = window.setTimeout(() => setText(current.slice(0, text.length + 1)), typingSpeed)
      if (text === current) timeout = window.setTimeout(() => setIsDeleting(true), pause)
    } else {
      timeout = window.setTimeout(() => setText(current.slice(0, text.length - 1)), typingSpeed / 2)
      if (text === '') {
        setIsDeleting(false)
        setIdx((i) => i + 1)
      }
    }

    return () => window.clearTimeout(timeout)
  }, [text, isDeleting, idx, words, typingSpeed, pause])

  return text
}

function generateParticles(count = 18) {
  return Array.from({ length: count }).map((_, i) => ({
    id: i,
    size: Math.floor(Math.random() * 24) + 12,
    left: Math.random() * 100,
    top: Math.random() * 100,
    delay: Math.random() * 6,
    duration: 6 + Math.random() * 8,
    color: Math.random() > 0.65 ? 'bg-cyan-400/18' : 'bg-fuchsia-500/12',
  }))
}

